<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd" version="6.0">
<!--  ===== WELCOME PAGE =====  -->
<welcome-file-list>
<welcome-file>index.jsp</welcome-file>
</welcome-file-list>
<!--  ===== CART SERVLET =====  -->
<servlet>
<servlet-name>GioHangServlet</servlet-name>
<servlet-class>controller.GioHangServlet</servlet-class>
</servlet>
<servlet-mapping>
<servlet-name>GioHangServlet</servlet-name>
<url-pattern>/cart</url-pattern>
</servlet-mapping>
<!--  ===== LOGIN SERVLET (nếu có) =====  -->
<servlet>
<servlet-name>DangNhapServlet</servlet-name>
<servlet-class>controller.DangNhapServlet</servlet-class>
</servlet>
<servlet-mapping>
<servlet-name>DangNhapServlet</servlet-name>
<url-pattern>/login</url-pattern>
</servlet-mapping>
<!--  ===== REGISTER SERVLET (nếu có) =====  -->
<servlet>
<servlet-name>DangKyServlet</servlet-name>
<servlet-class>controller.DangKyServlet</servlet-class>
</servlet>
<servlet-mapping>
<servlet-name>DangKyServlet</servlet-name>
<url-pattern>/register</url-pattern>
</servlet-mapping>
<!--  ===== ENCODING FILTER (TRÁNH LỖI TIẾNG VIỆT) =====  -->
<filter>
<filter-name>encodingFilter</filter-name>
<filter-class>jakarta.servlet.Filter</filter-class>
</filter>
<filter-mapping>
<filter-name>encodingFilter</filter-name>
<url-pattern>/*</url-pattern>
</filter-mapping>
</web-app>